# --- Database Configuration ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=mailaroo
DB_PASS=mailaroo_pass
DB_NAME=mailaroo

# Primary connection string used by dbmate and the app
DATABASE_URL="postgres://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable"

# Application internal reference (must match DATABASE_URL)
MAILAROO_DATABASE_URL="${DATABASE_URL}"
DBMATE_SCHEMA_FILE=db/postgres.sql

# --- Webmail UI ---
MAILAROO_WEB_PORT=8080
# Required: base64-encoded 32-byte random key for CSRF protection.
# Generate with: openssl rand -base64 32
MAILAROO_WEB_CSRF_AUTH_KEY=
# Set to true only when running behind a trusted reverse proxy (nginx, Caddy, etc.)
# that sets X-Forwarded-For / X-Real-IP. Leaving this false prevents IP spoofing
# of the login rate limiter when the app is exposed directly.
MAILAROO_WEB_TRUST_PROXY=false

# --- Logging ---
# Levels: debug, info, warn, error
MAILAROO_LOG_LEVEL=info
# Formats: text, json
MAILAROO_LOG_FORMAT=text

# --- SMTP Inbound ---
MAILAROO_SMTP_DOMAIN=localhost
# Comma-separated list of ports
MAILAROO_SMTP_PORTS=25,2525,587,4650
# Paths to TLS certificates (Required for STARTTLS and implicit TLS on 465)
MAILAROO_SMTP_TLS_CERT_FILE=certs/cert.pem
MAILAROO_SMTP_TLS_KEY_FILE=certs/key.pem

# Optional smarthost relay for outbound mail (skips MX lookup).
# Useful for local dev with Mailpit: MAILAROO_SMTP_RELAY=localhost:1025
# MAILAROO_SMTP_RELAY=

# --- Spam & Filtering ---
# Comma-separated list of RBL servers
MAILAROO_SPAM_RBL_SERVERS=zen.spamhaus.org

# --- Storage ---
# Types: local, s3, gcs
MAILAROO_STORAGE_TYPE=local
# Compression: zstd, gzip, none
MAILAROO_COMPRESSION=zstd

# Local Storage settings
MAILAROO_LOCAL_STORAGE_BASE_PATH=./data/emails

# S3 Storage settings (uncomment if using S3)
# MAILAROO_S3_STORAGE_BUCKET=my-bucket
# MAILAROO_S3_STORAGE_REGION=us-east-1
# MAILAROO_S3_STORAGE_PREFIX=emails/
# MAILAROO_S3_STORAGE_ENDPOINT=http://localhost:9000 # For Minio

# GCS Storage settings (uncomment if using GCS)
# MAILAROO_GCS_STORAGE_BUCKET=my-gcp-bucket
# MAILAROO_GCS_STORAGE_PREFIX=emails/
