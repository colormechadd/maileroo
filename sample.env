# --- Database Configuration ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=maileroo
DB_PASS=maileroo_pass
DB_NAME=maileroo

# Primary connection string used by dbmate and the app
DATABASE_URL="postgres://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable"

# Application internal reference (must match DATABASE_URL)
MAILEROO_DATABASE_URL="${DATABASE_URL}"
DBMATE_SCHEMA_FILE=db/postgres.sql

# --- Webmail UI ---
MAILEROO_WEB_PORT=8080

# --- Logging ---
# Levels: debug, info, warn, error
MAILEROO_LOG_LEVEL=info
# Formats: text, json
MAILEROO_LOG_FORMAT=text

# --- SMTP Inbound ---
MAILEROO_SMTP_DOMAIN=localhost
# Comma-separated list of ports
MAILEROO_SMTP_PORTS=25,2525,587,4650
# Paths to TLS certificates (Required for STARTTLS and implicit TLS on 465)
MAILEROO_SMTP_TLS_CERT_FILE=certs/cert.pem
MAILEROO_SMTP_TLS_KEY_FILE=certs/key.pem

# --- Spam & Filtering ---
# Comma-separated list of RBL servers
MAILEROO_SPAM_RBL_SERVERS=zen.spamhaus.org

# --- Storage ---
# Types: local, s3, gcs
MAILEROO_STORAGE_TYPE=local
# Compression: zstd, gzip, none
MAILEROO_COMPRESSION=zstd

# Local Storage settings
MAILEROO_LOCAL_STORAGE_BASE_PATH=./data/emails

# S3 Storage settings (uncomment if using S3)
# MAILEROO_S3_STORAGE_BUCKET=my-bucket
# MAILEROO_S3_STORAGE_REGION=us-east-1
# MAILEROO_S3_STORAGE_PREFIX=emails/
# MAILEROO_S3_STORAGE_ENDPOINT=http://localhost:9000 # For Minio

# GCS Storage settings (uncomment if using GCS)
# MAILEROO_GCS_STORAGE_BUCKET=my-gcp-bucket
# MAILEROO_GCS_STORAGE_PREFIX=emails/
